# =============================================================================
# kiro-powers-mcp-kit — Environment Variables
# =============================================================================
# Copia este archivo como .env y completa con tus valores.
# NUNCA subas el .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Atlassian MCP (Jira + Confluence)
# -----------------------------------------------------------------------------
# Tu email de Atlassian (el mismo con el que te logueas a Jira)
ATLASSIAN_EMAIL=tu.email@empresa.com

# API Token personal de Atlassian
# Crear en: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_TOKEN=tu-api-token-aqui

# URL de tu site de Atlassian Cloud
ATLASSIAN_URL=https://jirasegurosbolivar.atlassian.net

# Proyecto de Jira por defecto (opcional, reduce token usage)
JIRA_PROJECT_KEY=TUPROJ

# Space ID de Confluence por defecto (opcional)
CONFLUENCE_SPACE_ID=123456

# -----------------------------------------------------------------------------
# Engram GO (opcional — solo si necesitas override)
# -----------------------------------------------------------------------------
# Directorio de datos de Engram (default: ~/.engram)
# ENGRAM_DATA_DIR=~/.engram

# Puerto del HTTP server (default: 7437, solo si usas engram serve)
# ENGRAM_PORT=7437

# -----------------------------------------------------------------------------
# Notas:
# - Para generar el base64 del token Atlassian:
#   echo -n "tu.email@empresa.com:tu-api-token" | base64
#
# - El MCP de Atlassian usa Basic Auth:
#   Authorization: Basic <base64(email:token)>
#
# - Si prefieres OAuth 2.1 en vez de API token, no necesitas estas variables.
#   La primera conexion abrira un browser para autorizar.
# =============================================================================
