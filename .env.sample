# =============================================================================
# kiro-powers-mcp-kit — Environment Variables
# =============================================================================
# Copia este archivo como .env y completa con tus valores.
# NUNCA subas el .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Jira Cloud MCP (@aashari/mcp-server-atlassian-jira)
# -----------------------------------------------------------------------------
# Tu site name de Atlassian (la parte antes de .atlassian.net)
# Ejemplo: si tu URL es https://jirasegurosbolivar.atlassian.net
#          entonces el site name es: jirasegurosbolivar
ATLASSIAN_SITE_NAME=jirasegurosbolivar

# Tu email de Atlassian (el mismo con el que te logueas a Jira)
ATLASSIAN_USER_EMAIL=tu.email@segurosbolivar.com

# API Token personal de Atlassian
# Crear en: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=tu-api-token-aqui

# -----------------------------------------------------------------------------
# Engram GO (opcional — solo si necesitas override)
# -----------------------------------------------------------------------------
# Directorio de datos de Engram (default: ~/.engram)
# ENGRAM_DATA_DIR=~/.engram

# Puerto del HTTP server (default: 7437, solo si usas engram serve)
# ENGRAM_PORT=7437

# =============================================================================
# COMO CONFIGURAR:
#
# 1. Copiar este archivo:
#    cp .env.sample .env
#
# 2. Editar .env con tus valores reales
#
# 3. Exportar las variables en tu shell:
#
#    macOS/Linux (agregar a ~/.zshrc o ~/.bashrc):
#      export ATLASSIAN_SITE_NAME="jirasegurosbolivar"
#      export ATLASSIAN_USER_EMAIL="tu.email@segurosbolivar.com"
#      export ATLASSIAN_API_TOKEN="tu-api-token"
#
#    Windows 11 (PowerShell, sin admin):
#      [System.Environment]::SetEnvironmentVariable("ATLASSIAN_SITE_NAME", "jirasegurosbolivar", "User")
#      [System.Environment]::SetEnvironmentVariable("ATLASSIAN_USER_EMAIL", "tu.email@segurosbolivar.com", "User")
#      [System.Environment]::SetEnvironmentVariable("ATLASSIAN_API_TOKEN", "tu-api-token", "User")
#
# 4. Reiniciar Kiro para que tome las variables
#
# 5. Verificar en Kiro: escribir "estatus" o probar una query de Jira
# =============================================================================
